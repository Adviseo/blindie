// BLINDIE — Firestore security rules (production)
//
// Modèle :
//   - rooms/{roomId}                    : doc principal, hostId = uid Auth du host
//   - rooms/{roomId}/tracks/{trackId}   : playlist enrichie iTunes (host-only en écriture)
//   - rooms/{roomId}/players/{playerId} : 1 doc par joueur, playerId == uid Auth
//   - rooms/{roomId}/answers/{answerId} : 1 doc par joueur (answerId == uid)
//
// Principes :
//   - Auth anonyme obligatoire pour TOUT.
//   - `get` séparé de `list` partout — personne ne doit pouvoir lister toutes
//     les rooms, ni les sous-collections d'une room dont il n'est pas
//     participant ou host.
//   - Host (= request.auth.uid == room.hostId) a tous les droits sur sa room.
//   - Participant (= existe dans players/{uid}) peut lire les sous-collections
//     de SA room et écrire sa propre réponse / son propre player doc.
//   - Joueur ne peut JAMAIS écrire un champ score* — c'est le host qui score.
//
// Statuts de room : "lobby" | "playing" | "locked" | "reveal" | "finished"

rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    match /rooms/{roomId} {

      // ----- Helpers room-level -----
      function isAuthed()     { return request.auth != null; }
      function isHost()       { return isAuthed() && resource.data.hostId == request.auth.uid; }
      function isHostOnNew()  { return isAuthed() && request.resource.data.hostId == request.auth.uid; }

      // ----- /rooms/{roomId} -----
      // get : autorisé pour permettre roomExists(code), join via code,
      //       listenRoom. Pas besoin d'être déjà participant.
      // list : INTERDIT — personne ne doit pouvoir énumérer les rooms.
      allow get:  if isAuthed();
      allow list: if false;

      // Création : hostId DOIT == request.auth.uid + champs minimaux
      allow create: if isHostOnNew()
                    && request.resource.data.status == 'lobby'
                    && request.resource.data.roomId == roomId
                    && request.resource.data.joinCode == roomId;
      // Update / delete : seul le host de la room
      allow update, delete: if isHost();

      // ===================================================================
      // tracks : la playlist enrichie iTunes. Lecture par les participants
      // de cette room ou le host (pour player.js qui query order==N et host.js
      // qui fetch toute la liste). Écriture host uniquement.
      // ===================================================================
      match /tracks/{trackId} {
        function parentRoom() {
          return get(/databases/$(database)/documents/rooms/$(roomId)).data;
        }
        function isHostHere() {
          return request.auth != null && parentRoom().hostId == request.auth.uid;
        }
        function isRoomParticipant() {
          return request.auth != null
            && exists(/databases/$(database)/documents/rooms/$(roomId)/players/$(request.auth.uid));
        }

        allow get:  if isRoomParticipant() || isHostHere();
        allow list: if isRoomParticipant() || isHostHere();
        allow create, update, delete: if isHostHere();
      }

      // ===================================================================
      // players : 1 doc par joueur. ID du doc = uid Auth du joueur.
      //   - Lecture (get/list) : host ou participant de la room.
      //   - Joueur s'inscrit avec name/joinedAt/lastSeen
      //   - Joueur ne peut updater QUE name/lastSeen (touchPlayer continue
      //     de marcher après que le host ait écrit `score`)
      //   - Joueur ne peut JAMAIS toucher au champ `score`
      //   - Host peut tout modifier (create stub via setDoc merge inclus)
      //   - Self-delete UNIQUEMENT en lobby ou finished — pas pendant un
      //     round (playing/locked/reveal) pour ne pas casser le scoring
      // ===================================================================
      match /players/{playerId} {
        function parentRoom() {
          return get(/databases/$(database)/documents/rooms/$(roomId)).data;
        }
        function isHostHere() {
          return request.auth != null && parentRoom().hostId == request.auth.uid;
        }
        function isRoomParticipant() {
          return request.auth != null
            && exists(/databases/$(database)/documents/rooms/$(roomId)/players/$(request.auth.uid));
        }
        function isSelf() {
          return request.auth != null && request.auth.uid == playerId;
        }
        // À la création, seuls ces 3 champs sont autorisés
        function playerCreateFields() {
          return request.resource.data.keys().hasOnly(['name', 'joinedAt', 'lastSeen']);
        }
        // Sur update, seules name/lastSeen peuvent changer (diff sur les clés
        // affectées, donc `score` ajouté par le host n'est pas un blocker).
        function playerUpdateAffectedOk() {
          return request.resource.data.diff(resource.data)
                   .affectedKeys().hasOnly(['name', 'lastSeen']);
        }
        // Self-delete autorisé uniquement quand la partie n'est pas active
        function canSelfDelete() {
          let r = parentRoom();
          return isSelf() && (r.status == 'lobby' || r.status == 'finished');
        }

        // get inclut isSelf() pour qu'un NOUVEAU joueur (pas encore
        // participant) puisse interroger son propre doc avant de le créer
        // — joinRoom fait un getDoc(players/{uid}) pour décider entre
        // create et update minimal.
        allow get:  if isSelf() || isRoomParticipant() || isHostHere();
        // list reste strictement réservé aux participants / host pour
        // éviter qu'un utilisateur non-participant scanne la liste.
        allow list: if isRoomParticipant() || isHostHere();

        // Le joueur crée son propre doc.
        // Le host peut aussi créer (cas edge : updatePlayerScore via setDoc
        // merge sur un doc supprimé → recrée un stub avec score).
        // On exige que la room existe pour bloquer la création de player
        // docs orphelins dans des rooms fantômes (DoS storage).
        allow create: if (
                        isSelf()
                        && playerCreateFields()
                        && exists(/databases/$(database)/documents/rooms/$(roomId))
                      )
                      || isHostHere();
        allow update: if (isSelf() && playerUpdateAffectedOk()) || isHostHere();
        allow delete: if canSelfDelete() || isHostHere();
      }

      // ===================================================================
      // answers : 1 doc par joueur, ID du doc = uid Auth du joueur.
      //   - Lecture (get/list) : host ou participant de la room.
      //   - Joueur n'écrit QUE sa réponse brute (sans champs score*),
      //     UNIQUEMENT pendant status == "playing" + bon currentRoundIndex
      //   - 1 seul doc actif par joueur (answerId == uid) — empêche les
      //     doublons qui gonfleraient le score.
      //   - Host peut tout (score au reveal, supprimer, etc.).
      // ===================================================================
      match /answers/{answerId} {
        function parentRoom() {
          return get(/databases/$(database)/documents/rooms/$(roomId)).data;
        }
        function isHostHere() {
          return request.auth != null && parentRoom().hostId == request.auth.uid;
        }
        function isRoomParticipant() {
          return request.auth != null
            && exists(/databases/$(database)/documents/rooms/$(roomId)/players/$(request.auth.uid));
        }
        function gameIsOpenForAnswers() {
          let r = parentRoom();
          return r.status == 'playing'
                 && request.resource.data.roundIndex == r.currentRoundIndex;
        }
        function isOwnAnswer() {
          return request.auth != null
                 && answerId == request.auth.uid
                 && request.resource.data.playerId == request.auth.uid;
        }
        function playerAnswerFields() {
          return request.resource.data.keys().hasOnly([
            'playerId', 'playerName', 'roundIndex',
            'titleAnswer', 'artistAnswer', 'submittedAt'
          ]);
        }

        allow get:  if isRoomParticipant() || isHostHere();
        allow list: if isRoomParticipant() || isHostHere();

        // Pour écrire une réponse, l'utilisateur doit être PARTICIPANT
        // (avoir un doc player dans cette room). Sans ça, un user authentifié
        // qui connaîtrait le code pourrait pousser des answers sans avoir
        // jamais rejoint le lobby.
        allow create: if isRoomParticipant()
                      && isOwnAnswer()
                      && playerAnswerFields()
                      && gameIsOpenForAnswers();
        allow update: if (
                        isRoomParticipant()
                        && isOwnAnswer()
                        && playerAnswerFields()
                        && gameIsOpenForAnswers()
                      )
                      || isHostHere();
        allow delete: if isHostHere();
      }
    }
  }
}
